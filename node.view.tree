	Scenes_header $mol_paragraph
		title @ \Сцены
	Add_scene $mol_button_major
		title @ \+ Сцена
		click? <=> add_scene? null
	Graph_link $mol_link
		arg *
			panel \graph
		sub /
			<= Graph_label @ \🕸 Граф сцен
	Scene_row* $mol_row
		sub /
			<= Scene_link* $mol_link
				arg *
